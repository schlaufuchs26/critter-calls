{
  "name": "animal-sound-guessr",
  "version": "2.0.0",
  "description": "A fun web game where you guess animals based on their sounds",
  "type": "module",
  "scripts": {
    "dev": "bun index.html",
    "build": "bun build index.html --outdir dist/ --target browser && cp -r sounds dist/",
    "start": "bun index.html",
    "test": "bun test",
    "tsc": "tsc --pretty --noEmit",
    "format": "biome format --write .",
    "biome": "biome check --error-on-warnings .",
    "knip": "knip",
    "checks": "bun run format && concurrently -g -c auto 'bun run tsc' 'bun run biome' 'bun run knip'",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@happy-dom/global-registrator": "^20.10.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "concurrently": "^10.0.3",
    "knip": "^6.16.1",
    "typescript": "^5.7.0"
  }
}
